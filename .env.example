# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# ── Session ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_secret

# ── Internal service auth ──────────────────────────────────────────────────────
# Shared secret between the Python bot and this dashboard
WEBHOOK_SECRET=change_me

# ── Seed admin (first deploy only) ────────────────────────────────────────────
# Login email for the default admin account created when the agents table is empty.
# Only used once on a fresh database — has no effect once any agent exists.
SEED_ADMIN_EMAIL=admin@yourdomain.com
# Password for the seed admin account (same variable used for runtime auth fallback)
DASHBOARD_PASSWORD=change_me_immediately

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=WAK Solutions <noreply@yourdomain.com>
MANAGER_EMAIL=manager@yourdomain.com

# ── Video (Daily.co) ──────────────────────────────────────────────────────────
DAILY_API_KEY=

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# ── WebAuthn (biometric login) ────────────────────────────────────────────────
# RP_ID = the domain without protocol, e.g. wak-agent.up.railway.app
RP_ID=
# RP_ORIGIN = full origin, e.g. https://wak-agent.up.railway.app
RP_ORIGIN=

# ── App URLs ───────────────────────────────────────────────────────────────────
APP_URL=https://wak-agent.up.railway.app
DASHBOARD_URL=https://wak-agent.up.railway.app

# ── OpenAI (for AI message summary) ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic (for chatbot setup conversation generation) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server binding ─────────────────────────────────────────────────────────────
PORT=5000
HOST=0.0.0.0
